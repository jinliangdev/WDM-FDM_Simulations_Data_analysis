def get_edges(norm, threshold=0.5):
    # detect rising and falling edges in a waveform
    # by scanning for thrshold crossings and returning a list of index and directions pairs
    # 1 being rising, 0 being falling
    edges = []
    for i in range(1, len(norm)):
        if norm[i-1] < threshold and norm[i] >= threshold:
            edges.append((i, 1))
        elif norm[i-1] >= threshold and norm[i] < threshold:
            edges.append((i, 0))
    return edges

def decode_from_edges(edges, spb):
    # rebuilds the bit sequence from edge positions
    # between consectuve edges, number of bit periods elapsed is estimated
    # by dividing the edge to edge gamp by samples per pit
    # each period is assigned the value held during that inerval
    decoded = []
    for i in range(len(edges)-1):
        n = max(1, round((edges[i+1][0] - edges[i][0]) / spb))
        decoded.extend([edges[i][1]] * n)
    return np.array(decoded)

def find_preamble_skip(decoded, bitsV_full, max_skip=20):
    #find the alignment offset that minimises bit error.
    # the received stream may be offset by a few bits due to edge fector, missing the first transision
    # wmitigate this by skipping some bits from the start, and picking the offest that minimises
    # Hamming distance

    best_errs, best_skip = len(decoded), 0
    for skip in range(max_skip):
        bV   = bitsV_full[skip:]
        n    = min(len(decoded), len(bV))
        errs = np.sum(decoded[:n] != bV[:n].astype(int))
        if errs < best_errs:
            best_errs, best_skip = errs, skip
    return best_skip

def analyse(datafile, bitsfile, freq):
    # function to load and invert voltage data
    #normalise to 0 and 1
    # detect edge and decode a rough bit stream
    # sample the received waveform at centre of each bit period
    # compute mean 0 and 1 level, BER
    datat, dataV = np.loadtxt(datafile, unpack=True, skiprows=1, delimiter=",")
    bitst, bitsV = np.loadtxt(bitsfile, unpack=True, skiprows=1, delimiter=",")

        # oscilloscope captured an inverted signal
    dataV_inv = -dataV
    # sampling rate from scope time axis 
    fs  = len(datat) / (datat[-1] - datat[0])
    #samples per bit, kept as float 
    spb = fs / freq

    #normalise
    norm    = (dataV_inv - dataV_inv.min()) / (dataV_inv.max() - dataV_inv.min())
    raw_inv = dataV_inv

    #try to find sample index of first detected rising edge
    edges      = get_edges(norm)
    first_edge = edges[0][0]
    # the bit files store 100 samples per bit, taking the middle point of each
    #bit to get either 0 or 1
    stored_spb = 100
    bitsV_full = np.array([bitsV[i*stored_spb + stored_spb//2]
                            for i in range(len(bitsV)//stored_spb)])

    decoded_edges = decode_from_edges(edges, spb)
    preamble_skip = find_preamble_skip(decoded_edges, bitsV_full)
    bitsV_seq     = bitsV_full[preamble_skip:]

    # sampling bit at center.
    n_bits    = len(bitsV_seq)
    rx_levels = np.array([
        norm[int(first_edge + (i + 0.5) * spb)]
        for i in range(n_bits)
        if int(first_edge + (i + 0.5) * spb) < len(norm)
    ])
    rx_raw = np.array([
        raw_inv[int(first_edge + (i + 0.5) * spb)]
        for i in range(n_bits)
        if int(first_edge + (i + 0.5) * spb) < len(raw_inv)
    ])

    n_valid   = len(rx_levels)
    bitsV_cmp = bitsV_seq[:n_valid]

    # compute metrics, mean levels for 0 and 1 bit, normalised in mV
    mean0_norm = np.mean(rx_levels[bitsV_cmp == 0])
    mean1_norm = np.mean(rx_levels[bitsV_cmp == 1])
    mean0_raw  = np.mean(rx_raw[bitsV_cmp == 0]) * 1000
    mean1_raw  = np.mean(rx_raw[bitsV_cmp == 1]) * 1000

    #dynamic threshold based on midpoint between the 2 mean lsevels, this optimises
    #for symmetric noise.
    threshold = (mean0_norm + mean1_norm) / 2
    rx_bits   = (rx_levels > threshold).astype(int)
    errors    = np.sum(rx_bits != bitsV_cmp.astype(int))
    ber       = errors / n_valid

    #upsample the sequence to match oscilloscope sample rate
    samplespb_int = int(spb)
    tx_upsampled  = np.repeat(bitsV_seq, samplespb_int).astype(float)
    t_tx          = np.linspace(0, n_valid / freq, len(tx_upsampled))
    rx_burst      = norm[first_edge: first_edge + len(tx_upsampled)]
    t_burst_shift = np.linspace(0, len(rx_burst) / fs, len(rx_burst))

    return dict(mean0_norm=mean0_norm, mean1_norm=mean1_norm,
                mean0_raw=mean0_raw,   mean1_raw=mean1_raw,
                eye_norm=mean1_norm - mean0_norm,
                eye_raw=mean1_raw - mean0_raw,
                ber=ber, errors=errors, n=n_valid,
                threshold=threshold,
                rx_levels=rx_levels, bitsV_cmp=bitsV_cmp,
                rx_burst=rx_burst, t_burst=t_burst_shift,
                tx_upsampled=tx_upsampled, t_tx=t_tx)

